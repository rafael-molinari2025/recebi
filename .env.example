# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Database
DATABASE_URL=postgresql://postgres:[password]@db.seu-projeto.supabase.co:5432/postgres

# Asaas (gateway de pagamento)
ASAAS_API_KEY=sua-api-key-asaas
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Em produção: https://www.asaas.com/api/v3

# WhatsApp (Evolution API ou Z-API)
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sua-api-key-whatsapp
WHATSAPP_INSTANCE=recebi

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=gere-um-secret-aleatorio
